# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Pooled connection string from your Neon project dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/clearcut?sslmode=require

# ── Auth.js ────────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Set to your production URL on Vercel; http://localhost:3000 for local
AUTH_URL=http://localhost:3000

# Google OAuth — create at console.cloud.google.com
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Resend (email magic link) ──────────────────────────────────────────────────
# Create key at resend.com/api-keys
AUTH_RESEND_KEY=
EMAIL_FROM=login@yourdomain.com
